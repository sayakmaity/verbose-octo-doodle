{
  "manifest_version": 3,
  "name": "Gmail Code Clipper",
  "version": "1.0.0",
  "description": "Monitors Gmail for login/verification codes and copies them to your clipboard automatically",
  "permissions": [
    "identity",
    "storage",
    "notifications",
    "offscreen",
    "alarms",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://gmail.googleapis.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://oauth2.googleapis.com/*",
    "https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gmail Code Clipper",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
